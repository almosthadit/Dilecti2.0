# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Dilecti Platform Affiliate Tags
# These are applied globally as defaults to monetize outbound product links, 
# unless the user has provided their own custom tags in Settings.
VITE_DILECTI_AMAZON_TAG=
VITE_DILECTI_SKIMLINKS_ID=

# SERPAPI_API_KEY: Optional. Used to search Google Shopping for products.
SERPAPI_API_KEY=

# TMDB_API_KEY: Optional. The Movie Database API key. Greatly improves movie/TV search.
TMDB_API_KEY=

# RAWG_API_KEY: Optional. RAWG Video Games Database API key. Greatly improves video game search.
RAWG_API_KEY=

# GOOGLE_MAPS_API_KEY: Required for precise location and restaurant data.
GOOGLE_MAPS_API_KEY=

# GOOGLE_MAPS_PLATFORM_KEY: Required for interactive Google Maps visualizations.
GOOGLE_MAPS_PLATFORM_KEY=

# GOOGLE_CSE_API_KEY: Required to use Google Custom Search Engine for missing images.
GOOGLE_CSE_API_KEY=

# GOOGLE_CSE_CX: The Search Engine ID corresponding to the CSE API key.
GOOGLE_CSE_CX=

# GROQ_API_KEY: Optional. Used as a fallback if the Gemini API quota is exceeded.
GROQ_API_KEY=

# OPENROUTER_API_KEY: Optional. Used for OpenRouter AI provider.
OPENROUTER_API_KEY=
